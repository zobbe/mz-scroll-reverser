#!/bin/zsh
#
# pre-commit hook - basic sanity checks before allowing a commit
#
# Enabled by: git config core.hooksPath .githooks

fail=0

for f in sr install.sh uninstall.sh; do
  if [ -f "$f" ]; then
    # syntax check, doesn't execute anything
    if ! zsh -n "$f"; then
      echo "Syntax error in $f"
      fail=1
    fi
    # make sure the scripts stay executable
    if [ ! -x "$f" ]; then
      echo "$f lost its executable bit, run: chmod +x $f"
      fail=1
    fi
  fi
done

if command -v shellcheck >/dev/null 2>&1; then
  shellcheck -s bash sr install.sh uninstall.sh 2>/dev/null || true
fi

# reject commits if the configured email looks like a real address rather than
# the GitHub noreply address
author_email=$(git config user.email)
if [[ "$author_email" != *"@users.noreply.github.com" ]]; then
  echo ""
  echo "Commit rejected: author email '$author_email' is not a GitHub noreply address."
  echo "  Run: git config user.email \"zobbe@users.noreply.github.com\""
  echo ""
  fail=1
fi

exit $fail
