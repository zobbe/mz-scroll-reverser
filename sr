#!/bin/zsh
#
# sr - toggle macOS scroll direction (natural <-> traditional)
# https://github.com/zobbe/mz-scroll-reverser

current=$(defaults read -g com.apple.swipescrolldirection 2>/dev/null)

BOLD="\033[1m"
GREEN="\033[32m"
YELLOW="\033[33m"
RESET="\033[0m"

if [ "$current" = "1" ]; then
  defaults write -g com.apple.swipescrolldirection -bool false
  echo ""
  echo "${BOLD}${YELLOW}🔄 Scroll direction changed${RESET}"
  echo "   Now: ${BOLD}Traditional${RESET} (reversed)"
  echo ""
else
  defaults write -g com.apple.swipescrolldirection -bool true
  echo ""
  echo "${BOLD}${GREEN}🔄 Scroll direction changed${RESET}"
  echo "   Now: ${BOLD}Natural${RESET}"
  echo ""
fi

# apps cache this pref, force a refresh so it applies immediately
/System/Library/PrivateFrameworks/SystemAdministration.framework/Resources/activateSettings -u 2>/dev/null

exit 0
